{
  "name": "dotfiles-check",
  "displayName": "Dotfiles Check",
  "description": "Auto-link CLAUDE.md to your dotfiles repo and keep it synced",
  "version": "1.6.0",
  "publisher": "nico",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nic2045/vscode-dotfiles-check.git"
  },
  "bugs": {
    "url": "https://github.com/nic2045/vscode-dotfiles-check/issues"
  },
  "homepage": "https://github.com/nic2045/vscode-dotfiles-check#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "dotfiles",
    "claude",
    "claude-code",
    "git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotfiles-check.verify",
        "title": "Verify Dotfiles Setup"
      },
      {
        "command": "dotfiles-check.sync",
        "title": "Dotfiles: Sync Now"
      },
      {
        "command": "dotfiles-check.update",
        "title": "Dotfiles Check: Update Extension"
      }
    ],
    "configuration": {
      "title": "Dotfiles Check",
      "properties": {
        "dotfiles-check.allowedOwners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "nic2045"
          ],
          "description": "Git remote owners (GitHub user/org names) whose repos the dotfiles check will act on. Other repos are silently ignored."
        }
      }
    }
  }
}
